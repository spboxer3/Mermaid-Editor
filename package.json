{
  "name": "mermaid-editor",
  "version": "1.0.0",
  "description": "Mermaid diagram editor with drag-and-drop, grid snap, and custom colors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "interactjs": "^1.10.27",
    "mermaid": "^11.13.0"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.mermaid.editor",
    "productName": "Mermaid Editor",
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "i18n.js",
      "node_modules/**/*"
    ],
    "compression": "normal",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    }
  }
}
